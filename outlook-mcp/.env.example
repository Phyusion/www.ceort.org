# Microsoft Entra (Azure AD) application credentials.
# Register an app at https://entra.microsoft.com -> App registrations -> New registration.
# For personal + work accounts, pick "Accounts in any organizational directory and personal Microsoft accounts".
# Add the delegated Microsoft Graph permissions:
#   Mail.ReadWrite, Mail.Send, Calendars.ReadWrite, MailboxSettings.ReadWrite, offline_access, User.Read
OUTLOOK_CLIENT_ID=your-application-client-id
OUTLOOK_TENANT_ID=common

# Optional. Only required when AUTH_MODE=client_credentials (app-only access).
OUTLOOK_CLIENT_SECRET=

# AUTH_MODE: "device" (default, interactive device-code flow) or "client_credentials" (app-only).
AUTH_MODE=device

# Where the refresh-token cache is written. Defaults to ~/.outlook-mcp/token-cache.json.
# TOKEN_CACHE_PATH=/absolute/path/to/token-cache.json

# Default mailbox for app-only (client_credentials) mode. Ignored for device flow.
# OUTLOOK_USER_ID=user@example.com
